
#[set(everything)]
const constants: {
	WVP: float4x4;
};

struct vert_in {
	pos: float4;
}

struct vert_out {
	pos: float4;
}

fun mesh_vert(input: vert_in): vert_out {
	var output: vert_out;
	output.pos = constants.WVP * float4(input.pos.xyz, 1.0);
	output.pos.x = output.pos.x / output.pos.w;
	output.pos.y = output.pos.y / output.pos.w;
	output.pos.z = output.pos.z / output.pos.w;
	return output;
}

fun mesh_frag(input: vert_out): float4 {
	return float4(1.0, 0.0, 0.0, 1.0);
}

#[pipe]
struct pipe {
	vertex = mesh_vert;
	fragment = mesh_frag;
}