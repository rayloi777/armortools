float g_v16x = 0.0; float g_v16y = 0.0; int g_g16 = 1;
float g_v17x = 0.0; float g_v17y = 0.0; int g_g17 = 1;
float g_v18x = 0.0; float g_v18y = 0.0; int g_g18 = 1;
float g_v19x = 0.0; float g_v19y = 0.0; int g_g19 = 1;

// AI hop state
float g_ht0 = 1.0;  float g_hi0 = 1.0;  float g_sp0 = 1.0;
float g_ht1 = 1.12; float g_hi1 = 1.12; float g_sp1 = 1.08;
float g_ht2 = 1.24; float g_hi2 = 1.24; float g_sp2 = 1.16;
