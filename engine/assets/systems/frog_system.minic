// FrogSystem - 1 player + 20 AI frogs
// Stores velocity in script globals (avoids Flecs dynamic component write-back issue)

float GRAVITY = 2200.0;
float GROUND_Y = 560.0;
float JUMP_VEL = 600.0;
float PLAYER_SPEED = 250.0;

float g_pos_comp = -1.0;
float g_sprite_comp = -1.0;
float g_line_comp = -1.0;
float g_frog_comp = -1.0;
int g_frame = 0;

// Entities
float g_player = -1.0;
float g_ai0 = -1.0;  float g_ai1 = -1.0;  float g_ai2 = -1.0;  float g_ai3 = -1.0;  float g_ai4 = -1.0;
float g_ai5 = -1.0;  float g_ai6 = -1.0;  float g_ai7 = -1.0;  float g_ai8 = -1.0;  float g_ai9 = -1.0;
float g_ai10 = -1.0; float g_ai11 = -1.0; float g_ai12 = -1.0; float g_ai13 = -1.0; float g_ai14 = -1.0;
float g_ai15 = -1.0; float g_ai16 = -1.0; float g_ai17 = -1.0; float g_ai18 = -1.0; float g_ai19 = -1.0;

// Velocity stored in script globals (bypass Flecs dynamic comp write-back issue)
float g_pv_x = 0.0; float g_pv_y = 0.0; int g_pground = 1;
float g_v0x = 0.0;  float g_v0y = 0.0;  int g_g0 = 1;
float g_v1x = 0.0;  float g_v1y = 0.0;  int g_g1 = 1;
float g_v2x = 0.0;  float g_v2y = 0.0;  int g_g2 = 1;
