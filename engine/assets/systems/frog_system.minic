float g_ht6 = 1.72; float g_hi6 = 1.72; float g_sp6 = 1.48;
float g_ht7 = 1.84; float g_hi7 = 1.84; float g_sp7 = 1.56;
float g_ht8 = 1.96; float g_hi8 = 1.96; float g_sp8 = 1.64;
float g_ht9 = 2.08; float g_hi9 = 2.08; float g_sp9 = 1.72;
float g_ht10 = 2.2; float g_hi10 = 2.2; float g_sp10 = 1.8;
float g_ht11 = 2.32; float g_hi11 = 2.32; float g_sp11 = 1.88;
float g_ht12 = 2.44; float g_hi12 = 2.44; float g_sp12 = 1.96;
float g_ht13 = 2.56; float g_hi13 = 2.56; float g_sp13 = 2.04;
float g_ht14 = 2.68; float g_hi14 = 2.68; float g_sp14 = 2.12;
float g_ht15 = 2.8;  float g_hi15 = 2.8;  float g_sp15 = 2.2;
float g_ht16 = 2.92; float g_hi16 = 2.92; float g_sp16 = 2.28;
float g_ht17 = 3.04; float g_hi17 = 3.04; float g_sp17 = 2.36;
float g_ht18 = 3.16; float g_hi18 = 3.16; float g_sp18 = 2.44;
float g_ht19 = 3.28; float g_hi19 = 3.28; float g_sp19 = 2.52;

int g_jump_pressed = 0;

float create_frog(float x, float y, float scale, int layer) {
    float e = entity_create();
    entity_add(e, g_pos_comp);
    entity_add(e, g_sprite_comp);
    void *pos = entity_get(e, g_pos_comp);
    comp_set_float(g_pos_comp, pos, "x", x);
    comp_set_float(g_pos_comp, pos, "y", y);
    void *spr = entity_get(e, g_sprite_comp);
    comp_set_float(g_sprite_comp, spr, "scale_x", scale);
    comp_set_float(g_sprite_comp, spr, "scale_y", scale);
    comp_set_bool(g_sprite_comp, spr, "visible", 1);
    comp_set_int(g_sprite_comp, spr, "layer", layer);
    sprite_create(e, "frog_idle.k");
    return e;
}

int init(void) {
    printf("FrogSystem: Init\n");
    g_pos_comp = component_lookup("comp_2d_position");
    g_sprite_comp = component_lookup("comp_2d_sprite");
    g_line_comp = component_lookup("comp_2d_line");
    printf("  pos=%g sprite=%g line=%g\n", g_pos_comp, g_sprite_comp, g_line_comp);

    // Ground line
    float ge = entity_create();
    entity_add(ge, g_line_comp);
    void *line = entity_get(ge, g_line_comp);
    comp_set_float(g_line_comp, line, "x0", -2000.0);
    comp_set_float(g_line_comp, line, "y0", GROUND_Y);
    comp_set_float(g_line_comp, line, "x1", 4000.0);
    comp_set_float(g_line_comp, line, "y1", GROUND_Y);
    comp_set_float(g_line_comp, line, "strength", 3.0);
    comp_set_int(g_line_comp, line, "color", 0xff4a752a);
    comp_set_int(g_line_comp, line, "layer", 5);
    comp_set_bool(g_line_comp, line, "visible", 1);

    // Player
    g_player = create_frog(640.0, GROUND_Y, 2.5, 30);

    // AI frogs at various positions
    g_ai0 = create_frog(100.0, GROUND_Y, 1.5, 10);
    g_ai1 = create_frog(200.0, GROUND_Y, 1.8, 10);
    g_ai2 = create_frog(300.0, GROUND_Y, 1.3, 10);
    g_ai3 = create_frog(400.0, GROUND_Y, 2.0, 10);
    g_ai4 = create_frog(500.0, GROUND_Y, 1.6, 10);
    g_ai5 = create_frog(600.0, GROUND_Y, 1.4, 10);
    g_ai6 = create_frog(700.0, GROUND_Y, 1.7, 10);
    g_ai7 = create_frog(800.0, GROUND_Y, 2.2, 10);
    g_ai8 = create_frog(900.0, GROUND_Y, 1.2, 10);
    g_ai9 = create_frog(1000.0, GROUND_Y, 1.9, 10);
    g_ai10 = create_frog(150.0, GROUND_Y, 1.5, 10);
    g_ai11 = create_frog(250.0, GROUND_Y, 2.1, 10);
    g_ai12 = create_frog(350.0, GROUND_Y, 1.4, 10);
    g_ai13 = create_frog(450.0, GROUND_Y, 1.8, 10);
    g_ai14 = create_frog(550.0, GROUND_Y, 1.6, 10);
    g_ai15 = create_frog(650.0, GROUND_Y, 2.0, 10);
    g_ai16 = create_frog(750.0, GROUND_Y, 1.3, 10);
    g_ai17 = create_frog(850.0, GROUND_Y, 1.7, 10);
    g_ai18 = create_frog(950.0, GROUND_Y, 2.3, 10);
    g_ai19 = create_frog(1050.0, GROUND_Y, 1.1, 10);

    printf("FrogSystem: ready (1 player + 20 AI)\n");
    return 0;
}

void update_player(float dt) {
    void *pos = entity_get(g_player, g_pos_comp);
    if (!pos) return;
    float px = comp_get_float(g_pos_comp, pos, "x");
    float py = comp_get_float(g_pos_comp, pos, "y");
    float vx = g_pv_x;
    float vy = g_pv_y;

    // Input
    vx = 0.0;
    if (keyboard_down("left")) vx = -PLAYER_SPEED;
    if (keyboard_down("right")) vx = PLAYER_SPEED;
    int space = keyboard_down("space");
    if (space && g_pground && g_jump_pressed == 0) {
        vy = -JUMP_VEL;
    }
    g_jump_pressed = space;

    // Physics
    vy = vy + GRAVITY * dt;
    px = px + vx * dt;
    py = py + vy * dt;

    // Ground
    if (py >= GROUND_Y) {
        py = GROUND_Y;
        vy = 0.0;
        g_pground = 1;
    } else {
        g_pground = 0;
    }

    // Bounds
    if (px < 20.0) { px = 20.0; vx = 0.0; }
    if (px > 1260.0) { px = 1260.0; vx = 0.0; }

    comp_set_float(g_pos_comp, pos, "x", px);
    comp_set_float(g_pos_comp, pos, "y", py);
    g_pv_x = vx;
    g_pv_y = vy;
}

void update_ai(int entity, float vx_ptr, float vy_ptr, int ground_ptr,
               float ht_ptr, float hi_ptr, float sp_ptr, float dt) {
    void *pos = entity_get(entity, g_pos_comp);
    if (!pos) return;

    float px = comp_get_float(g_pos_comp, pos, "x");
    float py = comp_get_float(g_pos_comp, pos, "y");

    // These are passed by value in minic, so we use globals directly
    // This function is not used - inline the AI update instead
    py = py + 1.0; // placeholder
}

int step(void) {
    float dt = sys_delta_time();
    g_frame = g_frame + 1;
    if (g_frame <= 3) printf("step() frame=%d dt=%g\n", g_frame, dt);
    if (dt <= 0.0) dt = 0.016;
    if (dt > 0.05) dt = 0.05;

    // === Player ===
    update_player(dt);

    // === AI frogs (inline physics for each) ===

    // AI 0
    {
        g_ht0 = g_ht0 - dt;
        if (g_ht0 <= 0.0 && g_g0) {
            g_v0y = -(400.0 + g_sp0 * 200.0);
            float r = rand_float();
            if (r < 0.33) g_v0x = -g_sp0 * 100.0;
            else if (r < 0.66) g_v0x = g_sp0 * 100.0;
            g_ht0 = g_hi0;
        }
        g_v0y = g_v0y + GRAVITY * dt;
        void *p = entity_get(g_ai0, g_pos_comp);
        if (p) {
            float px = comp_get_float(g_pos_comp, p, "x");
            float py = comp_get_float(g_pos_comp, p, "y");
            px = px + g_v0x * dt;
            py = py + g_v0y * dt;
            if (py >= GROUND_Y) { py = GROUND_Y; g_v0y = 0.0; g_g0 = 1; } else { g_g0 = 0; }
            if (px < 20.0) { px = 20.0; g_v0x = -g_v0x; }
            if (px > 1260.0) { px = 1260.0; g_v0x = -g_v0x; }
            comp_set_float(g_pos_comp, p, "x", px);
            comp_set_float(g_pos_comp, p, "y", py);
        }
    }

    // AI 1
    {
        g_ht1 = g_ht1 - dt;
        if (g_ht1 <= 0.0 && g_g1) {
            g_v1y = -(400.0 + g_sp1 * 200.0);
            float r = rand_float();
            if (r < 0.33) g_v1x = -g_sp1 * 100.0;
            else if (r < 0.66) g_v1x = g_sp1 * 100.0;
            g_ht1 = g_hi1;
        }
        g_v1y = g_v1y + GRAVITY * dt;
        void *p = entity_get(g_ai1, g_pos_comp);
        if (p) {
            float px = comp_get_float(g_pos_comp, p, "x");
            float py = comp_get_float(g_pos_comp, p, "y");
            px = px + g_v1x * dt;
            py = py + g_v1y * dt;
            if (py >= GROUND_Y) { py = GROUND_Y; g_v1y = 0.0; g_g1 = 1; } else { g_g1 = 0; }
            if (px < 20.0) { px = 20.0; g_v1x = -g_v1x; }
            if (px > 1260.0) { px = 1260.0; g_v1x = -g_v1x; }
            comp_set_float(g_pos_comp, p, "x", px);
            comp_set_float(g_pos_comp, p, "y", py);
        }
    }

    // AI 2
    {
        g_ht2 = g_ht2 - dt;
        if (g_ht2 <= 0.0 && g_g2) {
            g_v2y = -(400.0 + g_sp2 * 200.0);
            float r = rand_float();
            if (r < 0.33) g_v2x = -g_sp2 * 100.0;
            else if (r < 0.66) g_v2x = g_sp2 * 100.0;
            g_ht2 = g_hi2;
        }
        g_v2y = g_v2y + GRAVITY * dt;
        void *p = entity_get(g_ai2, g_pos_comp);
        if (p) {
            float px = comp_get_float(g_pos_comp, p, "x");
            float py = comp_get_float(g_pos_comp, p, "y");
            px = px + g_v2x * dt;
            py = py + g_v2y * dt;
            if (py >= GROUND_Y) { py = GROUND_Y; g_v2y = 0.0; g_g2 = 1; } else { g_g2 = 0; }
            if (px < 20.0) { px = 20.0; g_v2x = -g_v2x; }
            if (px > 1260.0) { px = 1260.0; g_v2x = -g_v2x; }
            comp_set_float(g_pos_comp, p, "x", px);
            comp_set_float(g_pos_comp, p, "y", py);
        }
    }

    // AI 3
    {
        g_ht3 = g_ht3 - dt;
        if (g_ht3 <= 0.0 && g_g3) {
            g_v3y = -(400.0 + g_sp3 * 200.0);
            float r = rand_float();
            if (r < 0.33) g_v3x = -g_sp3 * 100.0;
            else if (r < 0.66) g_v3x = g_sp3 * 100.0;
            g_ht3 = g_hi3;
        }
        g_v3y = g_v3y + GRAVITY * dt;
        void *p = entity_get(g_ai3, g_pos_comp);
        if (p) {
            float px = comp_get_float(g_pos_comp, p, "x");
            float py = comp_get_float(g_pos_comp, p, "y");
            px = px + g_v3x * dt;
            py = py + g_v3y * dt;
            if (py >= GROUND_Y) { py = GROUND_Y; g_v3y = 0.0; g_g3 = 1; } else { g_g3 = 0; }
            if (px < 20.0) { px = 20.0; g_v3x = -g_v3x; }
            if (px > 1260.0) { px = 1260.0; g_v3x = -g_v3x; }
            comp_set_float(g_pos_comp, p, "x", px);
            comp_set_float(g_pos_comp, p, "y", py);
        }
    }

    // AI 4
    {
        g_ht4 = g_ht4 - dt;
        if (g_ht4 <= 0.0 && g_g4) {
            g_v4y = -(400.0 + g_sp4 * 200.0);
            float r = rand_float();
            if (r < 0.33) g_v4x = -g_sp4 * 100.0;
            else if (r < 0.66) g_v4x = g_sp4 * 100.0;
            g_ht4 = g_hi4;
        }
        g_v4y = g_v4y + GRAVITY * dt;
        void *p = entity_get(g_ai4, g_pos_comp);
        if (p) {
            float px = comp_get_float(g_pos_comp, p, "x");
            float py = comp_get_float(g_pos_comp, p, "y");
            px = px + g_v4x * dt;
            py = py + g_v4y * dt;
            if (py >= GROUND_Y) { py = GROUND_Y; g_v4y = 0.0; g_g4 = 1; } else { g_g4 = 0; }
            if (px < 20.0) { px = 20.0; g_v4x = -g_v4x; }
            if (px > 1260.0) { px = 1260.0; g_v4x = -g_v4x; }
            comp_set_float(g_pos_comp, p, "x", px);
            comp_set_float(g_pos_comp, p, "y", py);
        }
    }

    // AI 5-19: same pattern, different globals
    // For brevity, using the same inline pattern
    g_ht5 = g_ht5 - dt;
    if (g_ht5 <= 0.0 && g_g5) { g_v5y = -(400.0 + g_sp5 * 200.0); float r = rand_float(); if (r < 0.33) g_v5x = -g_sp5 * 100.0; else if (r < 0.66) g_v5x = g_sp5 * 100.0; g_ht5 = g_hi5; }
    g_v5y = g_v5y + GRAVITY * dt;
    { void *p = entity_get(g_ai5, g_pos_comp); if (p) { float px = comp_get_float(g_pos_comp, p, "x"); float py = comp_get_float(g_pos_comp, p, "y"); px = px + g_v5x * dt; py = py + g_v5y * dt; if (py >= GROUND_Y) { py = GROUND_Y; g_v5y = 0.0; g_g5 = 1; } else { g_g5 = 0; } if (px < 20.0) { px = 20.0; g_v5x = -g_v5x; } if (px > 1260.0) { px = 1260.0; g_v5x = -g_v5x; } comp_set_float(g_pos_comp, p, "x", px); comp_set_float(g_pos_comp, p, "y", py); } }

    g_ht6 = g_ht6 - dt;
    if (g_ht6 <= 0.0 && g_g6) { g_v6y = -(400.0 + g_sp6 * 200.0); float r = rand_float(); if (r < 0.33) g_v6x = -g_sp6 * 100.0; else if (r < 0.66) g_v6x = g_sp6 * 100.0; g_ht6 = g_hi6; }
    g_v6y = g_v6y + GRAVITY * dt;
    { void *p = entity_get(g_ai6, g_pos_comp); if (p) { float px = comp_get_float(g_pos_comp, p, "x"); float py = comp_get_float(g_pos_comp, p, "y"); px = px + g_v6x * dt; py = py + g_v6y * dt; if (py >= GROUND_Y) { py = GROUND_Y; g_v6y = 0.0; g_g6 = 1; } else { g_g6 = 0; } if (px < 20.0) { px = 20.0; g_v6x = -g_v6x; } if (px > 1260.0) { px = 1260.0; g_v6x = -g_v6x; } comp_set_float(g_pos_comp, p, "x", px); comp_set_float(g_pos_comp, p, "y", py); } }

    g_ht7 = g_ht7 - dt;
    if (g_ht7 <= 0.0 && g_g7) { g_v7y = -(400.0 + g_sp7 * 200.0); float r = rand_float(); if (r < 0.33) g_v7x = -g_sp7 * 100.0; else if (r < 0.66) g_v7x = g_sp7 * 100.0; g_ht7 = g_hi7; }
    g_v7y = g_v7y + GRAVITY * dt;
    { void *p = entity_get(g_ai7, g_pos_comp); if (p) { float px = comp_get_float(g_pos_comp, p, "x"); float py = comp_get_float(g_pos_comp, p, "y"); px = px + g_v7x * dt; py = py + g_v7y * dt; if (py >= GROUND_Y) { py = GROUND_Y; g_v7y = 0.0; g_g7 = 1; } else { g_g7 = 0; } if (px < 20.0) { px = 20.0; g_v7x = -g_v7x; } if (px > 1260.0) { px = 1260.0; g_v7x = -g_v7x; } comp_set_float(g_pos_comp, p, "x", px); comp_set_float(g_pos_comp, p, "y", py); } }

    g_ht8 = g_ht8 - dt;
    if (g_ht8 <= 0.0 && g_g8) { g_v8y = -(400.0 + g_sp8 * 200.0); float r = rand_float(); if (r < 0.33) g_v8x = -g_sp8 * 100.0; else if (r < 0.66) g_v8x = g_sp8 * 100.0; g_ht8 = g_hi8; }
    g_v8y = g_v8y + GRAVITY * dt;
