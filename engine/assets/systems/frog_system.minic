    g_v17y = g_v17y + GRAVITY * dt;
    { void *p = entity_get(g_ai17, g_pos_comp); if (p) { float px = comp_get_float(g_pos_comp, p, "x"); float py = comp_get_float(g_pos_comp, p, "y"); px = px + g_v17x * dt; py = py + g_v17y * dt; if (py >= GROUND_Y) { py = GROUND_Y; g_v17y = 0.0; g_g17 = 1; } else { g_g17 = 0; } if (px < 20.0) { px = 20.0; g_v17x = -g_v17x; } if (px > 1260.0) { px = 1260.0; g_v17x = -g_v17x; } comp_set_float(g_pos_comp, p, "x", px); comp_set_float(g_pos_comp, p, "y", py); } }

    g_ht18 = g_ht18 - dt;
    if (g_ht18 <= 0.0 && g_g18) { g_v18y = -(400.0 + g_sp18 * 200.0); float r = rand_float(); if (r < 0.33) g_v18x = -g_sp18 * 100.0; else if (r < 0.66) g_v18x = g_sp18 * 100.0; g_ht18 = g_hi18; }
    g_v18y = g_v18y + GRAVITY * dt;
    { void *p = entity_get(g_ai18, g_pos_comp); if (p) { float px = comp_get_float(g_pos_comp, p, "x"); float py = comp_get_float(g_pos_comp, p, "y"); px = px + g_v18x * dt; py = py + g_v18y * dt; if (py >= GROUND_Y) { py = GROUND_Y; g_v18y = 0.0; g_g18 = 1; } else { g_g18 = 0; } if (px < 20.0) { px = 20.0; g_v18x = -g_v18x; } if (px > 1260.0) { px = 1260.0; g_v18x = -g_v18x; } comp_set_float(g_pos_comp, p, "x", px); comp_set_float(g_pos_comp, p, "y", py); } }

    g_ht19 = g_ht19 - dt;
    if (g_ht19 <= 0.0 && g_g19) { g_v19y = -(400.0 + g_sp19 * 200.0); float r = rand_float(); if (r < 0.33) g_v19x = -g_sp19 * 100.0; else if (r < 0.66) g_v19x = g_sp19 * 100.0; g_ht19 = g_hi19; }
    g_v19y = g_v19y + GRAVITY * dt;
    { void *p = entity_get(g_ai19, g_pos_comp); if (p) { float px = comp_get_float(g_pos_comp, p, "x"); float py = comp_get_float(g_pos_comp, p, "y"); px = px + g_v19x * dt; py = py + g_v19y * dt; if (py >= GROUND_Y) { py = GROUND_Y; g_v19y = 0.0; g_g19 = 1; } else { g_g19 = 0; } if (px < 20.0) { px = 20.0; g_v19x = -g_v19x; } if (px > 1260.0) { px = 1260.0; g_v19x = -g_v19x; } comp_set_float(g_pos_comp, p, "x", px); comp_set_float(g_pos_comp, p, "y", py); } }

    // Camera follow player
    void *ppos = entity_get(g_player, g_pos_comp);
    if (ppos) {
        float px = comp_get_float(g_pos_comp, ppos, "x");
        float py = comp_get_float(g_pos_comp, ppos, "y");
        camera_follow(px, py);
    }

    // Periodic debug
    if (g_frame % 180 == 1) {
        void *ppos2 = entity_get(g_player, g_pos_comp);
        if (ppos2) {
            float px = comp_get_float(g_pos_comp, ppos2, "x");
            float py = comp_get_float(g_pos_comp, ppos2, "y");
            printf("frame=%d player: x=%g y=%g vy=%g gnd=%d\n", g_frame, px, py, g_pv_y, g_pground);
        }
        void *ap = entity_get(g_ai0, g_pos_comp);
        if (ap) {
            float ax = comp_get_float(g_pos_comp, ap, "x");
            float ay = comp_get_float(g_pos_comp, ap, "y");
            printf("frame=%d ai0: x=%g y=%g vy=%g gnd=%d\n", g_frame, ax, ay, g_v0y, g_g0);
        }
    }

    return 0;
}

int draw(void) {
    draw_set_font("font.ttf", 16);
    draw_set_color(0xffffffff);
    draw_string("FrogSystem - Arrows + Space", 10.0, 10.0);
    draw_fps(10.0, 32.0);
    return 0;
}
