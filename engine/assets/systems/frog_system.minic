    g_ht9 = g_ht9 - dt;
    if (g_ht9 <= 0.0 && g_g9) { g_v9y = -(400.0 + g_sp9 * 200.0); float r = rand_float(); if (r < 0.33) g_v9x = -g_sp9 * 100.0; else if (r < 0.66) g_v9x = g_sp9 * 100.0; g_ht9 = g_hi9; }
    g_v9y = g_v9y + GRAVITY * dt;
    { void *p = entity_get(g_ai9, g_pos_comp); if (p) { float px = comp_get_float(g_pos_comp, p, "x"); float py = comp_get_float(g_pos_comp, p, "y"); px = px + g_v9x * dt; py = py + g_v9y * dt; if (py >= GROUND_Y) { py = GROUND_Y; g_v9y = 0.0; g_g9 = 1; } else { g_g9 = 0; } if (px < 20.0) { px = 20.0; g_v9x = -g_v9x; } if (px > 1260.0) { px = 1260.0; g_v9x = -g_v9x; } comp_set_float(g_pos_comp, p, "x", px); comp_set_float(g_pos_comp, p, "y", py); } }

    g_ht10 = g_ht10 - dt;
    if (g_ht10 <= 0.0 && g_g10) { g_v10y = -(400.0 + g_sp10 * 200.0); float r = rand_float(); if (r < 0.33) g_v10x = -g_sp10 * 100.0; else if (r < 0.66) g_v10x = g_sp10 * 100.0; g_ht10 = g_hi10; }
    g_v10y = g_v10y + GRAVITY * dt;
    { void *p = entity_get(g_ai10, g_pos_comp); if (p) { float px = comp_get_float(g_pos_comp, p, "x"); float py = comp_get_float(g_pos_comp, p, "y"); px = px + g_v10x * dt; py = py + g_v10y * dt; if (py >= GROUND_Y) { py = GROUND_Y; g_v10y = 0.0; g_g10 = 1; } else { g_g10 = 0; } if (px < 20.0) { px = 20.0; g_v10x = -g_v10x; } if (px > 1260.0) { px = 1260.0; g_v10x = -g_v10x; } comp_set_float(g_pos_comp, p, "x", px); comp_set_float(g_pos_comp, p, "y", py); } }

    g_ht11 = g_ht11 - dt;
    if (g_ht11 <= 0.0 && g_g11) { g_v11y = -(400.0 + g_sp11 * 200.0); float r = rand_float(); if (r < 0.33) g_v11x = -g_sp11 * 100.0; else if (r < 0.66) g_v11x = g_sp11 * 100.0; g_ht11 = g_hi11; }
    g_v11y = g_v11y + GRAVITY * dt;
