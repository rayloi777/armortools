    g_ht12 = g_ht12 - dt;
    if (g_ht12 <= 0.0 && g_g12) { g_v12y = -(400.0 + g_sp12 * 200.0); float r = rand_float(); if (r < 0.33) g_v12x = -g_sp12 * 100.0; else if (r < 0.66) g_v12x = g_sp12 * 100.0; g_ht12 = g_hi12; }
    g_v12y = g_v12y + GRAVITY * dt;
    { void *p = entity_get(g_ai12, g_pos_comp); if (p) { float px = comp_get_float(g_pos_comp, p, "x"); float py = comp_get_float(g_pos_comp, p, "y"); px = px + g_v12x * dt; py = py + g_v12y * dt; if (py >= GROUND_Y) { py = GROUND_Y; g_v12y = 0.0; g_g12 = 1; } else { g_g12 = 0; } if (px < 20.0) { px = 20.0; g_v12x = -g_v12x; } if (px > 1260.0) { px = 1260.0; g_v12x = -g_v12x; } comp_set_float(g_pos_comp, p, "x", px); comp_set_float(g_pos_comp, p, "y", py); } }

    g_ht13 = g_ht13 - dt;
    if (g_ht13 <= 0.0 && g_g13) { g_v13y = -(400.0 + g_sp13 * 200.0); float r = rand_float(); if (r < 0.33) g_v13x = -g_sp13 * 100.0; else if (r < 0.66) g_v13x = g_sp13 * 100.0; g_ht13 = g_hi13; }
    g_v13y = g_v13y + GRAVITY * dt;
    { void *p = entity_get(g_ai13, g_pos_comp); if (p) { float px = comp_get_float(g_pos_comp, p, "x"); float py = comp_get_float(g_pos_comp, p, "y"); px = px + g_v13x * dt; py = py + g_v13y * dt; if (py >= GROUND_Y) { py = GROUND_Y; g_v13y = 0.0; g_g13 = 1; } else { g_g13 = 0; } if (px < 20.0) { px = 20.0; g_v13x = -g_v13x; } if (px > 1260.0) { px = 1260.0; g_v13x = -g_v13x; } comp_set_float(g_pos_comp, p, "x", px); comp_set_float(g_pos_comp, p, "y", py); } }

    g_ht14 = g_ht14 - dt;
    if (g_ht14 <= 0.0 && g_g14) { g_v14y = -(400.0 + g_sp14 * 200.0); float r = rand_float(); if (r < 0.33) g_v14x = -g_sp14 * 100.0; else if (r < 0.66) g_v14x = g_sp14 * 100.0; g_ht14 = g_hi14; }
    g_v14y = g_v14y + GRAVITY * dt;
    { void *p = entity_get(g_ai14, g_pos_comp); if (p) { float px = comp_get_float(g_pos_comp, p, "x"); float py = comp_get_float(g_pos_comp, p, "y"); px = px + g_v14x * dt; py = py + g_v14y * dt; if (py >= GROUND_Y) { py = GROUND_Y; g_v14y = 0.0; g_g14 = 1; } else { g_g14 = 0; } if (px < 20.0) { px = 20.0; g_v14x = -g_v14x; } if (px > 1260.0) { px = 1260.0; g_v14x = -g_v14x; } comp_set_float(g_pos_comp, p, "x", px); comp_set_float(g_pos_comp, p, "y", py); } }

    g_ht15 = g_ht15 - dt;
    if (g_ht15 <= 0.0 && g_g15) { g_v15y = -(400.0 + g_sp15 * 200.0); float r = rand_float(); if (r < 0.33) g_v15x = -g_sp15 * 100.0; else if (r < 0.66) g_v15x = g_sp15 * 100.0; g_ht15 = g_hi15; }
    g_v15y = g_v15y + GRAVITY * dt;
    { void *p = entity_get(g_ai15, g_pos_comp); if (p) { float px = comp_get_float(g_pos_comp, p, "x"); float py = comp_get_float(g_pos_comp, p, "y"); px = px + g_v15x * dt; py = py + g_v15y * dt; if (py >= GROUND_Y) { py = GROUND_Y; g_v15y = 0.0; g_g15 = 1; } else { g_g15 = 0; } if (px < 20.0) { px = 20.0; g_v15x = -g_v15x; } if (px > 1260.0) { px = 1260.0; g_v15x = -g_v15x; } comp_set_float(g_pos_comp, p, "x", px); comp_set_float(g_pos_comp, p, "y", py); } }

    g_ht16 = g_ht16 - dt;
    if (g_ht16 <= 0.0 && g_g16) { g_v16y = -(400.0 + g_sp16 * 200.0); float r = rand_float(); if (r < 0.33) g_v16x = -g_sp16 * 100.0; else if (r < 0.66) g_v16x = g_sp16 * 100.0; g_ht16 = g_hi16; }
    g_v16y = g_v16y + GRAVITY * dt;
    { void *p = entity_get(g_ai16, g_pos_comp); if (p) { float px = comp_get_float(g_pos_comp, p, "x"); float py = comp_get_float(g_pos_comp, p, "y"); px = px + g_v16x * dt; py = py + g_v16y * dt; if (py >= GROUND_Y) { py = GROUND_Y; g_v16y = 0.0; g_g16 = 1; } else { g_g16 = 0; } if (px < 20.0) { px = 20.0; g_v16x = -g_v16x; } if (px > 1260.0) { px = 1260.0; g_v16x = -g_v16x; } comp_set_float(g_pos_comp, p, "x", px); comp_set_float(g_pos_comp, p, "y", py); } }

    g_ht17 = g_ht17 - dt;
