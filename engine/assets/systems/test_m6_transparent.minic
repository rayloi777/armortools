// test_m6_transparent — Transparent objects + PostFX test
// Keys: 1=Normal, 2=Depth, 4=SSAO, 5=Bloom

id g_pos_comp = 0;
id g_rot_comp = 0;
id g_scale_comp = 0;
id g_cam_comp = 0;
id g_mesh_comp = 0;
id g_render_comp = 0;
id g_trans_comp = 0;

id g_cam = 0;
id g_opaque_mesh = 0;
id g_glass_mesh = 0;
int g_debug_mode = 0;

int init(void) {
    printf("\n=== M6 Transparent Test ===\n");

    g_pos_comp = component_lookup("comp_3d_position");
    g_rot_comp = component_lookup("comp_3d_rotation");
    g_scale_comp = component_lookup("comp_3d_scale");
    g_cam_comp = component_lookup("comp_3d_camera");
    g_mesh_comp = component_lookup("comp_3d_mesh_renderer");
    g_render_comp = component_lookup("RenderObject3D");
    g_trans_comp = component_lookup("comp_3d_transparency");

    // Load mesh scene
    void *mesh_obj = mesh_load_arm("ship.arm");
    printf("Ship loaded: %p\n", mesh_obj);

    // Create opaque mesh entity
    g_opaque_mesh = entity_create();
    entity_add(g_opaque_mesh, g_pos_comp);
    entity_add(g_opaque_mesh, g_rot_comp);
    entity_add(g_opaque_mesh, g_scale_comp);
    entity_add(g_opaque_mesh, g_mesh_comp);
    entity_add(g_opaque_mesh, g_render_comp);
    comp_set_floats(g_pos_comp, entity_get(g_opaque_mesh, g_pos_comp), "x,y,z", 0.0, 0.0, 0.0);
    comp_set_floats(g_rot_comp, entity_get(g_opaque_mesh, g_rot_comp), "x,y,z,w", 0.0, 0.0, 0.0, 1.0);
    comp_set_floats(g_scale_comp, entity_get(g_opaque_mesh, g_scale_comp), "x,y,z", 1.0, 1.0, 1.0);
    comp_set_ptr(g_render_comp, entity_get(g_opaque_mesh, g_render_comp), "iron_mesh_object", mesh_obj);
    comp_set_bool(g_render_comp, entity_get(g_opaque_mesh, g_render_comp), "dirty", 1);
    comp_set_bool(g_mesh_comp, entity_get(g_opaque_mesh, g_mesh_comp), "visible", 1);

    // Add ground plane (opaque cube)
    void *ground_obj = mesh_add_arm("cube.arm");
    id ground = entity_create();
    entity_add(ground, g_pos_comp);
    entity_add(ground, g_rot_comp);
    entity_add(ground, g_scale_comp);
    entity_add(ground, g_mesh_comp);
    entity_add(ground, g_render_comp);
    comp_set_floats(g_pos_comp, entity_get(ground, g_pos_comp), "x,y,z", 0.0, -0.5, 0.0);
    comp_set_floats(g_rot_comp, entity_get(ground, g_rot_comp), "x,y,z,w", 0.0, 0.0, 0.0, 1.0);
    comp_set_floats(g_scale_comp, entity_get(ground, g_scale_comp), "x,y,z", 5.0, 0.1, 5.0);
    comp_set_ptr(g_render_comp, entity_get(ground, g_render_comp), "iron_mesh_object", ground_obj);
    comp_set_bool(g_render_comp, entity_get(ground, g_render_comp), "dirty", 1);
    comp_set_bool(g_mesh_comp, entity_get(ground, g_mesh_comp), "visible", 1);

    // Create transparent glass cube
    void *glass_obj = mesh_add_arm("cube.arm");
    g_glass_mesh = entity_create();
    entity_add(g_glass_mesh, g_pos_comp);
    entity_add(g_glass_mesh, g_rot_comp);
    entity_add(g_glass_mesh, g_scale_comp);
    entity_add(g_glass_mesh, g_mesh_comp);
    entity_add(g_glass_mesh, g_render_comp);
    entity_add(g_glass_mesh, g_trans_comp);
    comp_set_floats(g_pos_comp, entity_get(g_glass_mesh, g_pos_comp), "x,y,z", 2.0, 1.0, 0.0);
    comp_set_floats(g_rot_comp, entity_get(g_glass_mesh, g_rot_comp), "x,y,z,w", 0.0, 0.0, 0.0, 1.0);
    comp_set_floats(g_scale_comp, entity_get(g_glass_mesh, g_scale_comp), "x,y,z", 1.0, 1.0, 1.0);
    comp_set_ptr(g_render_comp, entity_get(g_glass_mesh, g_render_comp), "iron_mesh_object", glass_obj);
    comp_set_bool(g_render_comp, entity_get(g_glass_mesh, g_render_comp), "dirty", 1);
    comp_set_bool(g_mesh_comp, entity_get(g_glass_mesh, g_mesh_comp), "visible", 1);
    // Set transparency
    comp_set_floats(g_trans_comp, entity_get(g_glass_mesh, g_trans_comp), "opacity", 0.5);
    comp_set_int(g_trans_comp, entity_get(g_glass_mesh, g_trans_comp), "blend_mode", 0);  // alpha blend
    comp_set_bool(g_trans_comp, entity_get(g_glass_mesh, g_trans_comp), "two_sided", 1);

    // Create camera
    g_cam = entity_create();
    entity_add(g_cam, g_pos_comp);
    entity_add(g_cam, g_rot_comp);
    entity_add(g_cam, g_cam_comp);
    comp_set_floats(g_pos_comp, entity_get(g_cam, g_pos_comp), "x,y,z", 0.0, 3.0, 10.0);
    comp_set_floats(g_rot_comp, entity_get(g_cam, g_rot_comp), "x,y,z,w", 0.0, 0.0, 0.0, 1.0);
    comp_set_floats(g_cam_comp, entity_get(g_cam, g_cam_comp), "fov,near_plane,far_plane", 1.047, 0.1, 100.0);
    comp_set_bool(g_cam_comp, entity_get(g_cam, g_cam_comp), "perspective", 1);
    comp_set_bool(g_cam_comp, entity_get(g_cam, g_cam_comp), "active", 1);
    entity_set_name(g_cam, "main_camera");

    printf("=== M6 Init Complete ===\n\n");
    return 0;
}

int step(void) {
    if (keyboard_started("1") != 0.0) { g_debug_mode = 0; sys_3d_set_debug_mode(0); }
    if (keyboard_started("2") != 0.0) { g_debug_mode = 1; sys_3d_set_debug_mode(1); }
    if (keyboard_started("4") != 0.0) { g_debug_mode = 4; sys_3d_set_debug_mode(4); }
    if (keyboard_started("5") != 0.0) { g_debug_mode = 5; sys_3d_set_debug_mode(5); }
    return 0;
}

int draw(void) {
    draw_set_font("font.ttf", 16);
    draw_set_color(0xffffffff);
    draw_string("M6: Transparent + PostFX", 10.0, 10.0);
    if (g_debug_mode == 0) draw_string("Mode: Normal", 10.0, 30.0);
    if (g_debug_mode == 1) draw_string("Mode: Depth", 10.0, 30.0);
    if (g_debug_mode == 4) draw_string("Mode: SSAO", 10.0, 30.0);
    if (g_debug_mode == 5) draw_string("Mode: Bloom", 10.0, 30.0);
    draw_string("1=Normal 2=Depth 4=SSAO 5=Bloom", 10.0, 50.0);
    draw_fps(10.0, 70.0);
    return 0;
}
