// Minimal text rendering test
int init(void) {
    printf("TextTest: Init\n");
    return 0;
}

int step(void) {
    return 0;
}

int draw(void) {
    // Test 1: Simple colored rectangle
    draw_set_color(0xffff0000);
    draw_filled_rect(100.0, 100.0, 200.0, 50.0);

    // Test 2: Text
    draw_set_color(0xffffffff);
    draw_set_font("font.ttf", 20);
    draw_string("HELLO WORLD", 120.0, 110.0);

    // Test 3: Circle
    draw_set_color(0xff00ff00);
    draw_filled_circle(500.0, 300.0, 30.0, 16);

    // Test 4: Line
    draw_set_color(0xff0000ff);
    draw_line(50.0, 50.0, 700.0, 50.0, 3.0);

    return 0;
}
