// test_m7_decal — Decal projection test
// Keys: 1=Normal, 2=Depth, 4=SSAO, 5=Bloom

id g_pos_comp = 0;
id g_rot_comp = 0;
id g_scale_comp = 0;
id g_cam_comp = 0;
id g_mesh_comp = 0;
id g_render_comp = 0;
id g_decal_comp = 0;

id g_cam = 0;
int g_debug_mode = 0;

int init(void) {
    printf("\n=== M7 Decal Test ===\n");

    g_pos_comp = component_lookup("comp_3d_position");
    g_rot_comp = component_lookup("comp_3d_rotation");
    g_scale_comp = component_lookup("comp_3d_scale");
    g_cam_comp = component_lookup("comp_3d_camera");
    g_mesh_comp = component_lookup("comp_3d_mesh_renderer");
    g_render_comp = component_lookup("RenderObject3D");
    g_decal_comp = component_lookup("comp_3d_decal");

    // Load opaque ground plane
    void *ground_obj = mesh_load_arm("cube.arm");
    id ground = entity_create();
    entity_add(ground, g_pos_comp);
    entity_add(ground, g_rot_comp);
    entity_add(ground, g_scale_comp);
    entity_add(ground, g_mesh_comp);
    entity_add(ground, g_render_comp);
    comp_set_floats(g_pos_comp, entity_get(ground, g_pos_comp), "x,y,z", 0.0, -0.5, 0.0);
    comp_set_floats(g_rot_comp, entity_get(ground, g_rot_comp), "x,y,z,w", 0.0, 0.0, 0.0, 1.0);
    comp_set_floats(g_scale_comp, entity_get(ground, g_scale_comp), "x,y,z", 5.0, 0.1, 5.0);
    comp_set_ptr(g_render_comp, entity_get(ground, g_render_comp), "iron_mesh_object", ground_obj);
    comp_set_bool(g_render_comp, entity_get(ground, g_render_comp), "dirty", 1);
    comp_set_bool(g_mesh_comp, entity_get(ground, g_mesh_comp), "visible", 1);

    // Load opaque ship
    void *ship_obj = mesh_load_arm("ship.arm");
    id ship = entity_create();
    entity_add(ship, g_pos_comp);
    entity_add(ship, g_rot_comp);
    entity_add(ship, g_scale_comp);
    entity_add(ship, g_mesh_comp);
    entity_add(ship, g_render_comp);
    comp_set_floats(g_pos_comp, entity_get(ship, g_pos_comp), "x,y,z", 0.0, 0.0, 0.0);
    comp_set_floats(g_rot_comp, entity_get(ship, g_rot_comp), "x,y,z,w", 0.0, 0.0, 0.0, 1.0);
    comp_set_floats(g_scale_comp, entity_get(ship, g_scale_comp), "x,y,z", 1.0, 1.0, 1.0);
    comp_set_ptr(g_render_comp, entity_get(ship, g_render_comp), "iron_mesh_object", ship_obj);
    comp_set_bool(g_render_comp, entity_get(ship, g_render_comp), "dirty", 1);
    comp_set_bool(g_mesh_comp, entity_get(ship, g_mesh_comp), "visible", 1);

    // Create a decal on the ground (bullet hole)
    id decal1 = entity_create();
    entity_add(decal1, g_pos_comp);
    entity_add(decal1, g_decal_comp);
    comp_set_floats(g_pos_comp, entity_get(decal1, g_pos_comp), "x,y,z", 1.0, 0.0, 1.0);
    comp_set_floats(g_decal_comp, entity_get(decal1, g_decal_comp), "size_x,size_y,size_z", 0.5, 0.5, 0.5);
    comp_set_floats(g_decal_comp, entity_get(decal1, g_decal_comp), "opacity", 0.8);
    comp_set_floats(g_decal_comp, entity_get(decal1, g_decal_comp), "color_r,color_g,color_b", 0.2, 0.1, 0.0);
    comp_set_int(g_decal_comp, entity_get(decal1, g_decal_comp), "channel", 0);

    // Create another decal (red mark)
    id decal2 = entity_create();
    entity_add(decal2, g_pos_comp);
    entity_add(decal2, g_decal_comp);
    comp_set_floats(g_pos_comp, entity_get(decal2, g_pos_comp), "x,y,z", -1.5, 0.0, -0.5);
    comp_set_floats(g_decal_comp, entity_get(decal2, g_decal_comp), "size_x,size_y,size_z", 0.8, 0.8, 0.8);
    comp_set_floats(g_decal_comp, entity_get(decal2, g_decal_comp), "opacity", 0.6);
    comp_set_floats(g_decal_comp, entity_get(decal2, g_decal_comp), "color_r,color_g,color_b", 0.8, 0.1, 0.1);
    comp_set_int(g_decal_comp, entity_get(decal2, g_decal_comp), "channel", 0);

    // Create camera
    g_cam = entity_create();
    entity_add(g_cam, g_pos_comp);
    entity_add(g_cam, g_rot_comp);
    entity_add(g_cam, g_cam_comp);
    comp_set_floats(g_pos_comp, entity_get(g_cam, g_pos_comp), "x,y,z", 0.0, 3.0, 10.0);
    comp_set_floats(g_rot_comp, entity_get(g_cam, g_rot_comp), "x,y,z,w", 0.0, 0.0, 0.0, 1.0);
    comp_set_floats(g_cam_comp, entity_get(g_cam, g_cam_comp), "fov,near_plane,far_plane", 1.047, 0.1, 100.0);
    comp_set_bool(g_cam_comp, entity_get(g_cam, g_cam_comp), "perspective", 1);
    comp_set_bool(g_cam_comp, entity_get(g_cam, g_cam_comp), "active", 1);
    entity_set_name(g_cam, "main_camera");

    printf("=== M7 Init Complete ===\n\n");
    return 0;
}

int step(void) {
    if (keyboard_started("1") != 0.0) { g_debug_mode = 0; sys_3d_set_debug_mode(0); }
    if (keyboard_started("2") != 0.0) { g_debug_mode = 1; sys_3d_set_debug_mode(1); }
    if (keyboard_started("4") != 0.0) { g_debug_mode = 4; sys_3d_set_debug_mode(4); }
    if (keyboard_started("5") != 0.0) { g_debug_mode = 5; sys_3d_set_debug_mode(5); }
    return 0;
}

int draw(void) {
    draw_set_font("font.ttf", 16);
    draw_set_color(0xffffffff);
    draw_string("M7: Decals", 10.0, 10.0);
    if (g_debug_mode == 0) draw_string("Mode: Normal", 10.0, 30.0);
    if (g_debug_mode == 1) draw_string("Mode: Depth", 10.0, 30.0);
    if (g_debug_mode == 4) draw_string("Mode: SSAO", 10.0, 30.0);
    if (g_debug_mode == 5) draw_string("Mode: Bloom", 10.0, 30.0);
    draw_string("1=Normal 2=Depth 4=SSAO 5=Bloom", 10.0, 50.0);
    draw_fps(10.0, 70.0);
    return 0;
}
